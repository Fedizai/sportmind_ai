rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Progress photos (gym body-transformation tracking)
    match /progressPhotos/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Gym workout videos for AI form review
    match /gym-videos/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Football match/training videos for AI review
    match /football-videos/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Profile pictures - viewable by any signed-in user (avatars), editable by owner only
    match /profilePictures/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
