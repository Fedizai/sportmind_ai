rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper: read role from /users/{uid}
    function getUserRole(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.role;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdminOrCoach() {
      return request.auth != null && getUserRole(request.auth.uid) in ['admin', 'coach'];
    }

    // USERS
    match /users/{userId} {
      // Any signed-in user can read profiles (needed for messaging/team directory)
      allow read: if request.auth != null;

      // Create own
      allow create: if isOwner(userId);

      // Update: user can update own EXCEPT role/plan. Admin can update anything.
      // Exception: the two protected super-admin accounts can never have their
      // role changed away from 'admin', no matter who performs the update.
      allow update: if request.auth != null && (
        (request.auth.uid == userId &&
         !('role' in request.resource.data) &&
         !('plan' in request.resource.data)) ||
        getUserRole(request.auth.uid) == 'admin' ||
        // Coach/admin can update a player's status (available/injured/suspended)
        // without touching any other field on the profile.
        (isAdminOrCoach() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']))
      ) && (
        !(resource.data.get('email', '') in ['khaled05062006@gmail.com', 'fedizayen12@gmail.com']) ||
        request.resource.data.get('role', 'admin') == 'admin'
      );

      // Delete: admin only
      allow delete: if request.auth != null && getUserRole(request.auth.uid) == 'admin';

      // Coach-authored private notes about this player — coach/admin only,
      // not visible to or editable by the player themselves.
      match /coachNotes/{noteId} {
        allow read, write: if isAdminOrCoach();
      }

      // Per-user subcollections: gymVideos, footballVideos, progressPhotos, bodyweightLogs, etc.
      match /{subcollection}/{docId} {
        allow read, write: if isOwner(userId) || isAdminOrCoach();
      }
    }

    // SIGNUP / ONBOARDING ANSWERS
    // One doc per user: /signupAnswers/{userId}
    match /signupAnswers/{userId} {
      // CREATE: the signed-in user creates their own doc
      // Require userId field to match auth.uid
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.userId == request.auth.uid;

      // READ: owner, coach, admin
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        getUserRole(request.auth.uid) in ['admin','coach']
      );

      // UPDATE:
      // - Admin/coach can always edit
      // - Owner can edit too (remove the owner line if you want admin-only edits)
      allow update: if request.auth != null && (
        getUserRole(request.auth.uid) in ['admin','coach'] ||
        request.auth.uid == userId
      );

      // DELETE: admin only
      allow delete: if request.auth != null && getUserRole(request.auth.uid) == 'admin';
    }

    // NUTRITION LOGS
    match /nutritionLogs/{logId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdminOrCoach());
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || getUserRole(request.auth.uid) == 'admin');
    }

    // FOOTBALL MATCHES
    match /football_matches/{matchId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdminOrCoach());
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || getUserRole(request.auth.uid) == 'admin');
    }

    // TENNIS MATCHES
    match /tennis_matches/{matchId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdminOrCoach());
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || getUserRole(request.auth.uid) == 'admin');
    }

    // PERSONAL GOALS (athlete-set targets with progress tracking)
    match /goals/{goalId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdminOrCoach());
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || getUserRole(request.auth.uid) == 'admin');
    }

    // BODY SCANS (athlete body-composition scans + AI analysis history)
    match /bodyScans/{scanId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdminOrCoach());
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || getUserRole(request.auth.uid) == 'admin');
    }

    // COACH-MANAGED TEAM MATCHES (read-only for everyone signed in, managed by coach/admin)
    match /matches/{matchId} {
      allow read: if request.auth != null;
      allow write: if isAdminOrCoach();
    }

    // TRAINING SESSIONS (coach-created practice sessions, with attendance)
    match /trainingSessions/{sessionId} {
      allow read: if request.auth != null;
      allow write: if isAdminOrCoach();
    }

    // COACH MATCHES (schedule, lineups, tactics notes for the coach platform)
    match /coachMatches/{matchId} {
      allow read: if request.auth != null;
      allow write: if isAdminOrCoach();
    }

    // RESOURCES (drills, videos, documents, links — coach content library)
    match /resources/{resourceId} {
      allow read: if request.auth != null;
      allow write: if isAdminOrCoach();

      // Timeline comments on a resource (e.g. video review)
      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.resource.data.createdBy == request.auth.uid;
        allow update, delete: if request.auth != null &&
          (resource.data.createdBy == request.auth.uid || isAdminOrCoach());
      }
    }

    // PERFORMANCE REPORTS (coach-authored, player-targeted or whole-team)
    match /reports/{reportId} {
      allow read: if request.auth != null && (
        isAdminOrCoach() ||
        resource.data.targetPlayerUid == request.auth.uid ||
        resource.data.targetPlayerUid == null
      );
      allow write: if isAdminOrCoach();
    }

    // MESSAGING
    match /conversations/{conversationId} {
      allow read, update: if request.auth != null && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participants;

      match /messages/{messageId} {
        allow read, create: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
      }
    }
  }
}
